# ----------------------------------------
# AI Personal OS - Environment Configuration
# ----------------------------------------

# ===== AI ENGINE (Pydantic-AI) =====
# Inserisci qui la tua chiave API di Gemini.
# Puoi ottenerne una gratuitamente su: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ===== DATABASE =====
# Il percorso del database locale SQLite.
DATABASE_URL=sqlite+aiosqlite:///./sql_app.db

# ===== SECURITY =====
# Se devi abilitare le CORS Requests dal frontend (default Vite porta 5173 e 3000)
# BACKEND_CORS_ORIGINS=["http://localhost:5173", "http://127.0.0.1:5173"]
